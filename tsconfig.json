{
  "compilerOptions": {
    "isolatedModules": true,
    "jsx": "preserve",
    "module": "preserve",
    "noEmit": true,
    "noErrorTruncation": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "types": ["vite/client"],
    "verbatimModuleSyntax": true
  }
}
